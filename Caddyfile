slcoffline.com, slcoff.com {
    root * /srv/landing
    file_server
}

scope.slcoffline.com, scope.slcoff.com {
    reverse_proxy corescope:3000
}

mqtt.slcoffline.com, mqtt.slcoff.com {
    # MQTT runs on port 1883 (raw TCP)
    # This subdomain is for documentation/future WebSocket MQTT if needed
    respond "MQTT broker available on port 1883" 200
}

wsmqtt.slcoffline.com, ws.slcoff.com {
    reverse_proxy meshcore-mqtt-broker:8883
}

health.slcoffline.com, healthcheck.slcoffline.com, health.slcoff.com {
    reverse_proxy meshcore-health-check:3090
}

keygen.slcoffline.com {
    root * /srv/keygen
    file_server
}

livemap.slcoffline.com, map.slcoff.com {
    reverse_proxy meshmap-live:8080
}

observers.slcoffline.com {
    reverse_proxy observer-matrix:3100
}

# === Dev environments ===

dev-landing.slcoffline.com {
    root * /srv/dev-landing
    file_server
}

dev-scope.slcoffline.com {
    reverse_proxy corescope-dev:3000
}
