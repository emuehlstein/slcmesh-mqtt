chicagooffline.com {
    root * /srv/landing
    file_server
}

scope.chicagooffline.com {
    reverse_proxy corescope:3000
}

mqtt.chicagooffline.com {
    # MQTT runs on port 1883 (raw TCP)
    # This subdomain is for documentation/future WebSocket MQTT if needed
    respond "MQTT broker available on port 1883" 200
}

health.chicagooffline.com, healthcheck.chicagooffline.com {
    reverse_proxy meshcore-health-check:3090
}

# === Dev environments ===

dev-scope.chicagooffline.com {
    # Serve custom JS files (voices, etc.) directly
    handle /custom/* {
        root * /srv/dev-public
        uri strip_prefix /custom
        file_server
    }

    # Proxy everything else to dev CoreScope
    handle {
        reverse_proxy corescope-dev:3000
    }
}
