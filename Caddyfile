chicagooffline.com, chioff.com {
    root * /srv/landing
    file_server
}

scope.chicagooffline.com, scope.chioff.com {
    reverse_proxy corescope:3000
}

mqtt.chicagooffline.com, mqtt.chioff.com {
    # MQTT runs on port 1883 (raw TCP)
    # This subdomain is for documentation/future WebSocket MQTT if needed
    respond "MQTT broker available on port 1883" 200
}

wsmqtt.chicagooffline.com, ws.chioff.com {
    reverse_proxy meshcore-mqtt-broker:8883
}

health.chicagooffline.com, healthcheck.chicagooffline.com, health.chioff.com {
    reverse_proxy meshcore-health-check:3090
}

keygen.chicagooffline.com {
    root * /srv/keygen
    file_server
}

livemap.chicagooffline.com, map.chioff.com {
    reverse_proxy meshmap-live:8080
}

# === Dev environments ===

dev-landing.chicagooffline.com {
    root * /srv/dev-landing
    file_server
}

dev-scope.chicagooffline.com {
    reverse_proxy corescope-dev:3000
}
