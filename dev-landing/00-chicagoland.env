PACKETCAPTURE_MQTT4_QOS=0
PACKETCAPTURE_MQTT4_RETAIN=true
PACKETCAPTURE_MQTT4_KEEPALIVE=60

# -- rflab.io ------------------------------------------------------------------
PACKETCAPTURE_MQTT5_ENABLED=true
PACKETCAPTURE_MQTT5_SERVER=mqtt.rflab.io
PACKETCAPTURE_MQTT5_PORT=443
PACKETCAPTURE_MQTT5_TRANSPORT=websockets
