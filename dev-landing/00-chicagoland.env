PACKETCAPTURE_MQTT3_QOS=0
PACKETCAPTURE_MQTT3_RETAIN=true
PACKETCAPTURE_MQTT3_KEEPALIVE=60

# -- Chicago Offline prod (ws.chioff.com) --------------------------------------
PACKETCAPTURE_MQTT4_ENABLED=true
PACKETCAPTURE_MQTT4_SERVER=ws.chioff.com
PACKETCAPTURE_MQTT4_PORT=443
PACKETCAPTURE_MQTT4_TRANSPORT=websockets
