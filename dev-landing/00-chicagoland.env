# Chicagoland MeshCore Packet Capture Configuration
# For use with agessaman/meshcore-packet-capture (companions)
#
# Priority order: LetsMesh US → ChiMesh → ChiOff prod → ChiOff dev → rflab → LetsMesh EU
#
# Usage:
#   bash <(curl -fsSL https://raw.githubusercontent.com/agessaman/meshcore-packet-capture/main/install.sh) \
#     --config https://dev-landing.chicagooffline.com/00-chicagoland.env

# Region
PACKETCAPTURE_IATA=ORD

# -- 1. LetsMesh US --------------------------------------------------------
PACKETCAPTURE_MQTT1_ENABLED=true
PACKETCAPTURE_MQTT1_SERVER=mqtt-us-v1.letsmesh.net
PACKETCAPTURE_MQTT1_PORT=443
PACKETCAPTURE_MQTT1_TRANSPORT=websockets
PACKETCAPTURE_MQTT1_USE_TLS=true
PACKETCAPTURE_MQTT1_TLS_VERIFY=true
PACKETCAPTURE_MQTT1_USE_AUTH_TOKEN=***
PACKETCAPTURE_MQTT1_TOKEN_AUDIENCE=mqtt-us-v1.letsmesh.net
PACKETCAPTURE_MQTT1_QOS=0
PACKETCAPTURE_MQTT1_RETAIN=true
PACKETCAPTURE_MQTT1_KEEPALIVE=60

# -- 2. ChiMesh.org --------------------------------------------------------
PACKETCAPTURE_MQTT2_ENABLED=true
PACKETCAPTURE_MQTT2_SERVER=mqtt.chimesh.org
PACKETCAPTURE_MQTT2_PORT=443
PACKETCAPTURE_MQTT2_TRANSPORT=websockets
PACKETCAPTURE_MQTT2_USE_TLS=true
PACKETCAPTURE_MQTT2_TLS_VERIFY=true
PACKETCAPTURE_MQTT2_USE_AUTH_TOKEN=***
PACKETCAPTURE_MQTT2_TOKEN_AUDIENCE=mqtt.chimesh.org
PACKETCAPTURE_MQTT2_QOS=0
PACKETCAPTURE_MQTT2_RETAIN=true
PACKETCAPTURE_MQTT2_KEEPALIVE=60

# -- 3. Chicago Offline prod (ws.chioff.com) -------------------------------
PACKETCAPTURE_MQTT3_ENABLED=true
PACKETCAPTURE_MQTT3_SERVER=ws.chioff.com
PACKETCAPTURE_MQTT3_PORT=443
PACKETCAPTURE_MQTT3_TRANSPORT=websockets
PACKETCAPTURE_MQTT3_USE_TLS=true
PACKETCAPTURE_MQTT3_TLS_VERIFY=true
PACKETCAPTURE_MQTT3_USE_AUTH_TOKEN=***
PACKETCAPTURE_MQTT3_TOKEN_AUDIENCE=wsmqtt.chicagooffline.com
PACKETCAPTURE_MQTT3_QOS=0
PACKETCAPTURE_MQTT3_RETAIN=true
PACKETCAPTURE_MQTT3_KEEPALIVE=60

# -- 4. Chicago Offline dev ------------------------------------------------
PACKETCAPTURE_MQTT4_ENABLED=true
PACKETCAPTURE_MQTT4_SERVER=wsmqtt-dev.chicagooffline.com
PACKETCAPTURE_MQTT4_PORT=443
PACKETCAPTURE_MQTT4_TRANSPORT=websockets
PACKETCAPTURE_MQTT4_USE_TLS=true
PACKETCAPTURE_MQTT4_TLS_VERIFY=true
PACKETCAPTURE_MQTT4_USE_AUTH_TOKEN=***
PACKETCAPTURE_MQTT4_TOKEN_AUDIENCE=wsmqtt-dev.chicagooffline.com
PACKETCAPTURE_MQTT4_QOS=0
PACKETCAPTURE_MQTT4_RETAIN=true
PACKETCAPTURE_MQTT4_KEEPALIVE=60

# -- 5. rflab.io -----------------------------------------------------------
PACKETCAPTURE_MQTT5_ENABLED=true
PACKETCAPTURE_MQTT5_SERVER=mqtt.rflab.io
PACKETCAPTURE_MQTT5_PORT=443
PACKETCAPTURE_MQTT5_TRANSPORT=websockets
PACKETCAPTURE_MQTT5_USE_TLS=true
PACKETCAPTURE_MQTT5_TLS_VERIFY=true
PACKETCAPTURE_MQTT5_USE_AUTH_TOKEN=***
PACKETCAPTURE_MQTT5_TOKEN_AUDIENCE=mqtt.rflab.io
PACKETCAPTURE_MQTT5_QOS=0
PACKETCAPTURE_MQTT5_RETAIN=true
PACKETCAPTURE_MQTT5_KEEPALIVE=60

# -- 6. LetsMesh EU --------------------------------------------------------
PACKETCAPTURE_MQTT6_ENABLED=true
PACKETCAPTURE_MQTT6_SERVER=mqtt-eu-v1.letsmesh.net
PACKETCAPTURE_MQTT6_PORT=443
PACKETCAPTURE_MQTT6_TRANSPORT=websockets
