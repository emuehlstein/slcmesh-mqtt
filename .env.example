# .env.example — Copy to .env and fill in secrets before first deploy
#
# This file is NOT committed to git. deploy.sh generates it from CI secrets.

# ── CoreScope MQTT passwords ────────────────────────────────────────────────
BROKER_CORESCOPE_PASSWSLC=changeme
CHIMESH_VIEWER_PASSWSLC=changeme

# ── meshcore-mqtt-broker ────────────────────────────────────────────────────
BROKER_ADMIN_PASSWSLC=changeme

# ── Health Check ────────────────────────────────────────────────────────────
TEST_CHANNEL_SECRET=changeme
