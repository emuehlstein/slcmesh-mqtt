dev-scope.slcoffline.com {
    reverse_proxy corescope-dev:3000
}

dev-landing.slcoffline.com {
    root * /srv/dev-landing
    file_server
}

wsmqtt-dev.slcoffline.com {
    reverse_proxy meshcore-mqtt-broker:8883
}

dev-health.slcoffline.com {
    reverse_proxy meshcore-health-check-dev:3090
}

dev-keygen.slcoffline.com {
    root * /srv/keygen
    file_server
}

dev-livemap.slcoffline.com {
    reverse_proxy meshmap-live:8080
}

dev-observers.slcoffline.com {
    reverse_proxy observer-matrix:3100
}
