dev-scope.chicagooffline.com {
    reverse_proxy corescope-dev:3000
}

dev-landing.chicagooffline.com {
    root * /srv/dev-landing
    file_server
}

wsmqtt-dev.chicagooffline.com {
    reverse_proxy meshcore-mqtt-broker:8883
}

dev-health.chicagooffline.com {
    reverse_proxy meshcore-health-check-dev:3090
}

dev-keygen.chicagooffline.com {
    root * /srv/keygen
    file_server
}

dev-livemap.chicagooffline.com {
    reverse_proxy meshmap-live:8080
}

dev-observers.chicagooffline.com {
    reverse_proxy observer-matrix:3100
}
