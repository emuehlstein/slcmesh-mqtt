# meshcore-mqtt-broker config for chicagooffline dev
# Copy to .env and fill in real values on the dev server

# MQTT Server Settings
MQTT_WS_PORT=8883
MQTT_HOST=0.0.0.0

# Authentication - audience must match wsmqtt-dev.chicagooffline.com
AUTH_EXPECTED_AUDIENCE=wsmqtt-dev.chicagooffline.com

# Subscriber accounts
# CoreScope reads from the broker using this account (role 2 = full_access)
SUBSCRIBER_1=corescope:CHANGE_ME_CORESCOPE_PASSWORD:2

# Admin account for debugging/inspection (role 1 = admin, can see /internal topics)
SUBSCRIBER_2=admin:CHANGE_ME_ADMIN_PASSWORD:1:5

# Abuse detection (safe defaults for dev)
ABUSE_ENFORCEMENT_ENABLED=false
ABUSE_PERSISTENCE_PATH=/data/abuse-detection.db
