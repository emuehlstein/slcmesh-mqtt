# meshcore-mqtt-broker config for slcoffline dev
# Copy to .env and fill in real values on the dev server

# MQTT Server Settings
MQTT_WS_PORT=8883
MQTT_HOST=0.0.0.0

# Authentication - audience must match wsmqtt-dev.slcoffline.com
AUTH_EXPECTED_AUDIENCE=wsmqtt-dev.slcoffline.com

# Subscriber accounts
# CoreScope reads from the broker using this account (role 2 = full_access)
SUBSCRIBER_1=corescope:CHANGE_ME_CORESCOPE_PASSWSLC:2

# Admin account for debugging/inspection (role 1 = admin, can see /internal topics)
SUBSCRIBER_2=admin:CHANGE_ME_ADMIN_PASSWSLC:1:5

# Abuse detection (safe defaults for dev — all required vars must be present)
ABUSE_ENFORCEMENT_ENABLED=false
ABUSE_PERSISTENCE_PATH=/data/abuse-detection.db
ABUSE_DUPLICATE_WINDOW_SIZE=100
ABUSE_DUPLICATE_WINDOW_MS=300000
ABUSE_DUPLICATE_THRESHOLD=10
ABUSE_MAX_DUPLICATES_PER_PACKET=5
ABUSE_DUPLICATE_RATE_THRESHOLD=0.3
ABUSE_DUPLICATE_RATE_WINDOW_MS=300000
ABUSE_BUCKET_CAPACITY=20
ABUSE_BUCKET_REFILL_RATE=3
ABUSE_MAX_PACKET_SIZE=255
ABUSE_MAX_TOPICS_PER_DAY=3
ABUSE_ANOMALY_THRESHOLD=10
ABUSE_MAX_IATA_CHANGES_24H=3
ABUSE_TOPIC_HISTORY_SIZE=50
ABUSE_TOPIC_HISTORY_WINDOW_MS=86400000
ABUSE_PERSISTENCE_INTERVAL_MS=300000
SUBSCRIBER_MAX_CONNECTIONS_DEFAULT=2
